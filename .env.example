# Copy to .env and fill in the keys for the providers you plan to use.
# All keys are optional — the app will prompt for any missing key in the sidebar.

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Groq
GROQ_API_KEY=

# HuggingFace Inference API
HUGGINGFACEHUB_API_TOKEN=

# Ollama (local) — no key needed, just the base URL
OLLAMA_BASE_URL=http://localhost:11434
