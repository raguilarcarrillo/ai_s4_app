# Copy to .env and fill in the keys for the providers you plan to use.
# All keys are optional — the app will prompt for any missing key in the sidebar.

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Groq
GROQ_API_KEY=

# HuggingFace Inference API
HUGGINGFACEHUB_API_TOKEN=

# Ollama (local) — no key needed, just the base URL
OLLAMA_BASE_URL=http://localhost:11434

# ---- Optional: opt-in session persistence (sidebar toggle) ----
# Where uploaded files + FAISS indexes are persisted when a user enables
# "💾 Persist this session" in the sidebar. Defaults to ./.cache. Set to a
# durable mount on HF Spaces (e.g. /data/smart-teacher) if you've upgraded
# the Space to persistent storage; otherwise the cache lives only for the
# container's lifetime.
# SMART_TEACHER_CACHE_DIR=.cache
# Days of inactivity before a persisted session is auto-deleted (default 7).
# SMART_TEACHER_SESSION_TTL_DAYS=7
